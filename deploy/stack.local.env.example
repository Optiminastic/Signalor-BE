# ─────────────────────────────────────────────────────────────────────────
# Signalor backend — LOCAL Docker Compose env (deploy/docker-compose.local.yml).
#
#   cp stack.local.env.example stack.local.env   then fill the few blanks.
#   stack.local.env is gitignored. These are LOCAL-ONLY values — the DB
#   password etc. never leave your machine, so simple values are fine.
#
# Shared by web, worker, and analysis-worker.
# ─────────────────────────────────────────────────────────────────────────

# Production settings with TLS-only hardening relaxed for local http.
DJANGO_SETTINGS_MODULE=config.settings.local_prod

# ── Core ─────────────────────────────────────────────────────────────────
# Any non-empty value works locally. Generate one if you like:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=local-dev-not-a-real-secret-change-if-you-want

# Include the internal `web` service name (the web healthcheck / cross-service
# calls hit it by that host) plus loopback.
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,web

# Your locally-running frontend. Scheme included — used for CORS *and* CSRF.
CORS_ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_BASE_URL=http://localhost:3000

# Fernet key for stored OAuth tokens. Only needed if you exercise integrations
# locally. Generate one:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Database — the local `db` container ──────────────────────────────────
# Use DB_* (NOT DATABASE_URL): production settings force sslmode=require when
# DATABASE_URL is set, and the local Postgres container serves no TLS.
# Keep DB_PASSWORD and POSTGRES_PASSWORD identical.
DB_NAME=signalor
DB_USER=signalor
DB_PASSWORD=signalor
DB_HOST=db
DB_PORT=5432

POSTGRES_DB=signalor
POSTGRES_USER=signalor
POSTGRES_PASSWORD=signalor   # ← must equal DB_PASSWORD

# ── Redis — the local `redis` container (cache, throttling, sitemap broker) ─
REDIS_URL=redis://redis:6379/0
# Do NOT set CELERY_BROKER_URL — it is a reserved Celery var that overrides an
# app's own conf.broker_url and would force the analysis pipeline onto Redis,
# leaving the RabbitMQ app + its DLQ inert. Redis app reads REDIS_URL via
# settings; analysis app reads RABBITMQ_URL.

# ── RabbitMQ — the local `rabbitmq` container (analysis broker) ──────────
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//

# ── Telemetry: keep opentelemetry-instrument a no-op locally ─────────────
OTEL_SDK_DISABLED=true

# ── SiteOne technical crawler ──────────────────────────────────────────────
# SiteOne findings become technical tasks. Needs the siteone-crawler Linux binary
# baked into the image (Dockerfile --build-arg SITEONE_URL=...); false until then.
SIGNALOR_USE_SITEONE=false

# ── Django admin ─────────────────────────────────────────────────────────
ADMIN_URL=admin/

# ── Server-side screenshots (Chromium is baked into the image) ───────────
# Set 0 to save CPU/RAM locally if you don't need screenshot generation.
ENABLE_SERVER_SCREENSHOTS=1

# ── Plan / subscription gates — mirror prod. Set to false to test freely. ─
SUBSCRIPTION_REQUIRED=true
ENFORCE_PLAN_LIMITS=true
REQUIRE_SUBSCRIPTION_FOR_INTEGRATIONS=true

# ── AI / SERP providers — fill in if you run the analyzer pipeline ───────
OPENROUTER_API_KEY=
SERPER_API_KEY=
GEMINI_API_KEY=
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Email: local_prod.py routes mail to the console (container log), so no
# SendGrid credentials are needed here.
